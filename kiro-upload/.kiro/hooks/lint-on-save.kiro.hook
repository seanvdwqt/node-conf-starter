{
  "name": "Lint on Save",
  "version": "1.0.0",
  "description": "Run ESLint when TypeScript or TSX files are edited to catch issues early.",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*.ts", "**/*.tsx"]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint"
  }
}